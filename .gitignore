# Python cache/bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Test/cache/tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# IDE/editor
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Secrets/env files
.env
.env.*
!.env.example

# Project runtime/generated data (contains private info and local indexes)
data/index/
data/sessions/
data/uploads/
data/templates/
web/uploads/

# Ignore all files in data/raw but keep folder structure via .gitkeep
data/raw/**/*
!data/raw/**/.gitkeep

# Build artifacts
build/
dist/
*.egg-info/
